# Copie este arquivo para ".env" (sem o ".example") e preencha os valores reais.
# NUNCA suba o arquivo ".env" real para o GitHub ou qualquer repositório público —
# ele contém senhas. O ".gitignore" já está configurado para ignorá-lo.

# Senha do banco de dados PostgreSQL.
# Gere uma senha forte e aleatória, por exemplo rodando este comando no terminal:
#   openssl rand -base64 24
DB_PASSWORD=troque_esta_senha_por_uma_forte_e_aleatoria

# Chave secreta usada para assinar os tokens de login (JWT).
# Gere uma também com:
#   openssl rand -base64 48
# Trocar essa chave depois de já estar em uso desconecta todos os usuários logados
# (eles precisam fazer login de novo) — não tem outro efeito colateral.
JWT_SECRET=troque_esta_chave_por_uma_string_aleatoria_longa

# Porta em que o sistema vai responder no navegador (http://seu-servidor:HTTP_PORT).
# Use 80 se for o único site rodando nesse servidor e quiser acessar sem digitar porta.
HTTP_PORT=80

# Em produção, depois de configurar um domínio (ex: cs.creare.com.br), troque o "*" pelo
# domínio real para reforçar a segurança. Por enquanto, "*" funciona sem configuração extra.
CORS_ORIGIN=*
