# Copie este arquivo para ".env" (sem o ".example") e preencha os valores reais.
# NUNCA suba o arquivo ".env" real para o GitHub ou qualquer repositório público —
# ele contém senhas. O ".gitignore" já está configurado para ignorá-lo.

# Senha do banco de dados PostgreSQL.
# Gere uma senha forte e aleatória, por exemplo rodando este comando no terminal:
#   openssl rand -base64 24
DB_PASSWORD=troque_esta_senha_por_uma_forte_e_aleatoria

# Chave secreta usada para assinar os tokens de login (JWT).
# Gere uma também com:
#   openssl rand -base64 48
# Trocar essa chave depois de já estar em uso desconecta todos os usuários logados
# (eles precisam fazer login de novo) — não tem outro efeito colateral.
JWT_SECRET=troque_esta_chave_por_uma_string_aleatoria_longa

# Porta em que o sistema vai responder no navegador (http://seu-servidor:HTTP_PORT).
# Use 80 se for o único site rodando nesse servidor e quiser acessar sem digitar porta.
HTTP_PORT=80

# Em produção, depois de configurar um domínio (ex: cs.creare.com.br), troque o "*" pelo
# domínio real para reforçar a segurança. Por enquanto, "*" funciona sem configuração extra.
CORS_ORIGIN=*

# ── Integração com ClickUp (opcional) ─────────────────────────────────────────
# Deixe em branco para desativar. O sistema funciona normalmente sem essas variáveis.
# Quando preenchidas, ações, alertas críticos e reuniões são criados automaticamente
# como tarefas no ClickUp, e mudanças de status no ClickUp sincronizam de volta.
#
# Passo a passo para o time de TI:
#   1. No ClickUp, vá em Settings → Apps → API → Create Personal Token
#      Cole o token em CLICKUP_API_TOKEN abaixo.
#   2. Abra a lista do ClickUp onde as tarefas serão criadas,
#      copie o ID da URL (ex: https://app.clickup.com/123/v/li/99887766 → ID = 99887766)
#      Cole em CLICKUP_LIST_ID abaixo.
#   3. Para sincronização bidirecional (status ClickUp → CS Manager):
#      No ClickUp, vá em Settings → Integrations → Webhooks → Add Webhook
#      URL: https://SEU_SERVIDOR/api/clickup/webhook
#      Eventos: taskStatusUpdated, taskDeleted
#      Cole o "Secret" gerado em CLICKUP_WEBHOOK_SECRET abaixo (opcional mas recomendado).
#   4. Se os status da sua lista ClickUp tiverem nomes diferentes dos padrões abaixo,
#      ajuste as variáveis CLICKUP_STATUS_* com os nomes exatos usados na lista.

CLICKUP_API_TOKEN=
CLICKUP_LIST_ID=
CLICKUP_WEBHOOK_SECRET=

# Direção da integração:
#   false (padrão) — somente ClickUp → CS Manager:
#       Mudanças de status feitas no ClickUp atualizam automaticamente as ações aqui.
#       O CS Manager NÃO cria nem altera tarefas no ClickUp.
#   true — bidirecional:
#       Além de receber, o CS Manager também cria/atualiza/exclui tarefas no ClickUp
#       sempre que uma ação for criada, editada ou removida aqui.
CLICKUP_ENVIAR_TAREFAS=false

# Nomes dos status na lista ClickUp (padrão ClickUp — ajuste se necessário)
CLICKUP_STATUS_PENDENTE=to do
CLICKUP_STATUS_ANDAMENTO=in progress
CLICKUP_STATUS_CONCLUIDO=complete
CLICKUP_STATUS_CANCELADA=cancelled
